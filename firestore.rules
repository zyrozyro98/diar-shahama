rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق من تسجيل الدخول
    function isAuth() {
      return request.auth != null;
    }

    // وظيفة للتحقق من الرتبة من بيانات المستخدم
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role == 'admin';
    }

    function isSupervisor() {
      return isAuth() && (getUserData().role == 'supervisor' || isAdmin());
    }
    
    function isStaff() {
      return isAuth() && (getUserData().role == 'staff' || isSupervisor());
    }

    // قواعد المستخدمين
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin() || (isAuth() && request.auth.uid == userId);
    }

    // السيارات واللوحات (قراءة للجميع، كتابة للمدراء والموظفين)
    match /cars/{id} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /plates/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // الحجوزات (إضافة للجميع، قراءة وتعديل للموظفين)
    match /bookings/{id} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }
    
    // الإعلانات والشركاء
    match /ads/{id} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /partners/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // السجلات (إضافة فقط، قراءة للمدراء والمسؤولين)
    match /logs/{id} {
      allow create: if isAuth();
      allow read: if isSupervisor();
      allow update, delete: if false; 
    }

    // التحليلات (قراءة للمسؤولين، تحديث للجميع بحدود)
    match /analytics/{id} {
      allow read: if isSupervisor();
      allow write: if true; // يمكن تقييدها أكثر بناءً على الحقول
    }
    
    // الإشعارات
    match /notifications/{id} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.targetUser || isAdmin());
    }

    // منع الوصول لأي مستند غير معرف
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
