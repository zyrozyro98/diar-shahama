rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Role helpers (Note: This assumes a 'users' collection exists in Firestore too)
    // If only RTDB is used, these rules won't block RTDB but good to have if migration happens.
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSupervisor() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor';
    }
    
    function isStaff() {
      return isAuth() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff' || isAdmin() || isSupervisor());
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /cars/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /sales/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{id} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /plates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /agents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /specs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /logs/{id} {
      allow read: if isAdmin() || isSupervisor();
      allow write: if isAuth();
    }

    match /notifications/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /analytics/{id} {
      allow read: if isAdmin() || isSupervisor();
      allow write: if true;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
