rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuth() {
      return request.auth != null;
    }

    match /{allPaths=**} {
      // السماح بالقراءة للجميع لرؤية الصور
      allow read: if true;
      
      // السماح بالكتابة فقط للمسجلين مع قيود صارمة
      allow write: if isAuth() 
                   && request.resource.size < 5 * 1024 * 1024 // الحد الأقصى 5 ميجا
                   && request.resource.contentType.matches('image/.*'); // السماح بالصور فقط
      
      // السماح بالمسح فقط للمدراء (يمكن تخصيصها لاحقاً إذا وجد حقل role في التخزين)
      allow delete: if isAuth();
    }
  }
}
