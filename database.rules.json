{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')"
      },
      ".indexOn": ["role", "email"]
    },
    "cars": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["type", "make", "year", "price", "status"]
    },
    "settings": {
      ".read": true,
      ".write": "auth != null"
    },
    "bookings": {
      ".read": "auth != null",
      "$booking_id": {
        ".write": true,
        ".validate": "newData.hasChild('name') && newData.hasChild('phone')"
      }
    },
    "ads": {
      ".read": true,
      ".write": "auth != null"
    },
    "config": {
      ".read": true,
      ".write": "auth != null"
    },
    "whatsapp_settings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "notifications": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null || newData.child('type').val() == 'new_booking'"
      }
    },
    "analytics": {
      ".read": "auth != null",
      ".write": true
    },
    "logs": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}