{
    "rules": {
        "users": {
            ".read": true,
            "$uid": {
                ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || auth.uid === $uid)"
            },
            ".indexOn": [
                "role",
                "email",
                "phone"
            ]
        },
        "cars": {
            ".read": true,
            ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
            ".indexOn": [
                "bodyType",
                "make",
                "model",
                "year",
                "price",
                "status",
                "isFeatured",
                "createdAt"
            ]
        },
        "ads": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
            ".indexOn": ["active", "position"]
        },
        "sales": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "bookings": {
            ".read": "auth != null",
            "$booking_id": {
                ".write": "!data.exists() || (auth != null && root.child('users').child(auth.uid).exists())",
                ".validate": "!data.exists() ? newData.hasChildren(['name', 'phone']) : true"
            },
            ".indexOn": ["status", "assignedTo", "createdAt", "phone"]
        },
        "config": {
            ".read": true,
            "lastAssignedStaffIndex_v2": {
                ".write": true,
                ".validate": "newData.isNumber()"
            },
            "$other": {
                ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
            }
        },
        "settings": {
            ".read": true,
            ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')"
        },
        "plates": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
            ".indexOn": ["code", "price", "createdAt"]
        },
        "partners": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "locations": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "brands": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "agents": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "specs": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "packages": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "blogs": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
            ".indexOn": ["createdAt", "category"]
        },
        "quickReplies": {
            ".read": "auth != null",
            ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')"
        },
        "reviews": {
            ".read": true,
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
            ".indexOn": ["rating", "createdAt"]
        },
        "logs": {
            ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
            ".write": "auth != null",
            ".indexOn": ["type", "userId", "timestamp"]
        },
        "notifications": {
            ".read": "auth != null",
            "$uid": {
                ".write": "auth != null || (newData.child('type').val() === 'new_booking')"
            },
            ".indexOn": ["userId", "read", "createdAt"]
        },
        "analytics": {
            ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'supervisor')",
            ".write": true
        },
        ".read": false,
        ".write": false
    }
}