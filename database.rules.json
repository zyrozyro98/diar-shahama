{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".validate": "newData.hasChildren(['email', 'role'])"
      },
      ".indexOn": ["role", "email"]
    },
    "cars": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')",
      "$car_id": {
        ".validate": "newData.hasChildren(['make', 'price', 'status']) && newData.child('price').isNumber() && newData.child('price').val() >= 0"
      },
      ".indexOn": ["type", "make", "year", "price", "status", "isFeatured", "createdAt"]
    },
    "settings": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    },
    "bookings": {
      ".read": "auth != null",
      "$booking_id": {
        ".write": "(!data.exists() && newData.exists()) || (auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff'))",
        ".validate": "newData.hasChildren(['name', 'phone', 'carRequested'])",
        "phone": {
          ".validate": "newData.isString() && newData.val().length >= 8"
        }
      },
      ".indexOn": ["status", "staffId", "createdAt", "phone"]
    },
    "ads": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    },
    "config": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "whatsapp_settings": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "quickReplies": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "notifications": {
      ".read": "auth != null",
      "$notif_id": {
        ".write": "auth != null || (!data.exists() && newData.child('type').val() == 'new_booking')",
        ".validate": "newData.hasChild('type')"
      },
      ".indexOn": ["read", "createdAt", "targetUser"]
    },
    "analytics": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'supervisor')",
      ".write": "newData.exists()", 
      "$metric": {
         ".write": true
      }
    },
    "logs": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'supervisor')",
      "$log_id": {
        ".write": "auth != null && !data.exists() && newData.exists()",
        ".validate": "newData.hasChildren(['action', 'timestamp'])"
      },
      ".indexOn": ["timestamp", "userId", "type"]
    },
    "plates": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "brands": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "agents": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'staff')"
    },
    "$other": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() == 'admin'"
    }
  }
}